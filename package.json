{
  "name": "local-work-log",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts,.tsx",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:backup": "node scripts/backup-db.mjs",
    "db:restore-check": "node scripts/restore-check-db.mjs",
    "wbs:template:preview": "node --import tsx scripts/import-wbs-template.mjs --dry-run",
    "wbs:template:import": "node --import tsx scripts/import-wbs-template.mjs --apply",
    "postinstall": "prisma generate",
    "export:today": "node scripts/export-today.mjs",
    "export:week": "node scripts/export-week.mjs",
    "report:today:claude": "bash scripts/daily-claude.sh",
    "report:today:codex": "bash scripts/daily-codex.sh",
    "report:week:claude": "bash scripts/weekly-claude.sh",
    "report:week:codex": "bash scripts/weekly-codex.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.4",
    "exceljs": "^4.4.0",
    "prisma": "^6.9.0",
    "tsx": "^4.23.1",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
